Bootstrap: docker
From: rockylinux/rockylinux:8.10

%arguments
    PYTHON_VERSION=3.11
    NODE_MAJOR=22

%post
    cp /usr/bin/true /usr/sbin/useradd
    cp /usr/bin/true /usr/sbin/groupadd
    
    dnf install -y git curl
    curl -fsSL https://rpm.nodesource.com/setup_{{NODE_MAJOR}}.x | bash -
    dnf install -y nodejs

    export UV_INSTALL_DIR=/usr/local/bin
    curl -LsSf https://astral.sh/uv/install.sh | sh

    export UV_ROOT_DIR=/opt/uv
    export UV_LINK_MODE=copy
    
    export UV_CACHE_DIR="${UV_ROOT_DIR}/cache"
    
    export UV_PYTHON_INSTALL_DIR="${UV_ROOT_DIR}/python"
    
    export UV_TOOL_DIR="${UV_ROOT_DIR}/tools"
    
    mkdir -p "$UV_CACHE_DIR" "$UV_PYTHON_INSTALL_DIR" "$UV_TOOL_DIR"

    uv python install "{{PYTHON_VERSION}}"

    uv venv --python "{{PYTHON_VERSION}}" /opt/myenv
    . /opt/myenv/bin/activate
    
    cd /
    git clone https://github.com/TioSisai/BaseAL.git
    cd BaseAL
    git clone https://github.com/bioacoustic-ai/bacpipe.git
    sed -i "/tensorflow==2.15.1; sys_platform == 'win32'/d" bacpipe/pyproject.toml
    UV_PROJECT_ENVIRONMENT=/opt/myenv uv sync

    # Install additional CUDA dependencies for TensorFlow GPU support (bacpipe guidance)
    UV_PROJECT_ENVIRONMENT=/opt/myenv uv pip install -r bacpipe/requirements_tf_gpu.txt

    uv cache clean
    dnf -y clean all

%environment
    export PYTHON_VERSION={{PYTHON_VERSION}}
    
    export UV_LINK_MODE=copy
    export UV_CACHE_DIR=/opt/uv/cache
    export UV_PYTHON_INSTALL_DIR=/opt/uv/python
    export UV_TOOL_DIR=/opt/uv/tools
    
    export PATH="/opt/myenv/bin:$PATH"